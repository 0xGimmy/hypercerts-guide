---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import DonateIsland from '../components/react/DonateIsland'

const locale = Astro.currentLocale ?? 'zh'
const t = locale === 'zh'
  ? { title: '捐款' }
  : { title: 'Donate' }
---
<Layout title={t.title} description={locale === 'zh' ? '選擇你想支持的組織，每筆捐款都將記錄在鏈上' : 'Choose organizations to support. Every donation is recorded on-chain.'}>
  <Header slot="header" />
  <div class="flex flex-col items-center gap-2 mb-8">
    <h1 class="text-3xl font-bold font-serif text-light-text dark:text-dark-text">{t.title}</h1>
    <p class="text-sm text-light-text-secondary dark:text-dark-text-secondary">{locale === 'zh' ? '選擇你想支持的組織，每筆捐款都將記錄在鏈上' : 'Choose organizations to support. Every donation is recorded on-chain.'}</p>
  </div>
  <DonateIsland client:only="react" locale={locale} />
</Layout>
