---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro'
import DonateButton from '../../components/react/DonateButton'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const orgs = await getCollection('orgs')
  return orgs.map((org) => ({
    params: { slug: org.slug },
    props: { org },
  }))
}

const { org } = Astro.props
const { Content } = await render(org)
const locale = org.data.locale ?? 'zh'
const officialSiteLabel = locale === 'zh' ? '官方網站' : 'Official Site'
---
<Layout title={org.data.title} description={org.data.description} image={org.data.image} type="article">
  <Header slot="header" />
  <article class="prose dark:prose-invert prose-lg max-w-3xl mx-auto">
    <div class="flex items-start justify-between gap-4 mb-6 not-prose">
      <div>
        {org.data.verified && (
          <span class="inline-flex items-center gap-1 text-xs font-medium text-accent bg-accent/10 dark:bg-accent/20 px-2 py-0.5 rounded mb-2">
            ✓ {locale === 'zh' ? '已驗證組織' : 'Verified'}
          </span>
        )}
        <h1 class="text-3xl font-bold font-serif text-light-text dark:text-dark-text mt-1">{org.data.title}</h1>
        {org.data.description && <p class="text-base text-light-text-secondary dark:text-dark-text-secondary mt-2">{org.data.description}</p>}
      </div>
      <div class="flex items-center gap-2 shrink-0 pt-6">
        {org.data.link && (
          <a href={org.data.link} target="_blank" rel="noopener noreferrer"
             class="px-4 py-2 rounded-md border border-light-border dark:border-dark-border text-accent hover:border-accent transition-colors text-sm whitespace-nowrap">
            {officialSiteLabel} ↗
          </a>
        )}
        {org.data.address && (
          <DonateButton
            client:only="react"
            orgName={org.data.title}
            orgWallet={org.data.address}
            locale={locale}
          />
        )}
      </div>
    </div>
    <hr class="!border-light-border dark:!border-dark-border" />
    <Content />
  </article>
</Layout>
