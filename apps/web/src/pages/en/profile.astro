---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro'
import ProfileIsland from '../../components/react/ProfileIsland'

const locale = Astro.currentLocale ?? 'en'
const t = locale === 'zh'
  ? { title: '個人' }
  : { title: 'Profile' }
---
<Layout title={t.title} description="View your donation history and impact certificates" noindex>
  <Header slot="header" />
  <h1 class="text-2xl font-bold mb-6">{t.title}</h1>
  <ProfileIsland client:only="react" locale={locale} />
</Layout>
