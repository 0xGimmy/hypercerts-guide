---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro'
import DonateIsland from '../../components/react/DonateIsland'

const locale = Astro.currentLocale ?? 'en'
const t = locale === 'zh'
  ? { title: '捐款' }
  : { title: 'Donate' }
---
<Layout title={t.title} description="Choose organizations to support. Every donation is recorded on-chain.">
  <Header slot="header" />
  <h1 class="text-2xl font-bold mb-6">{t.title}</h1>
  <DonateIsland client:only="react" locale={locale} />
</Layout>
