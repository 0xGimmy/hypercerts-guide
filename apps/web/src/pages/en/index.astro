---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro'
import OrgCard from '../../components/OrgCard.astro'
import HeroReveal from '../../components/react/HeroReveal'
import { getCollection } from 'astro:content'

const locale = Astro.currentLocale ?? 'en'
const orgs = await getCollection('orgs', ({ data }: { data: { locale: string } }) => data.locale === locale)

const pages = await getCollection('pages', ({ data }) => data.locale === locale)
const manifesto = pages.find((p) => p.slug.includes('manifesto'))
const heading = manifesto?.data.description ?? 'Unite through HyperTogatherings!'
---
<Layout
  title="Taiwan HyperAwesome Guidebook"
  description="Support local Taiwanese organizations through blockchain donations, every contribution recorded on-chain"
>
  <Header slot="header" />

  <!-- Hero -->
  <HeroReveal client:visible heading={heading} locale="en" />

  <!-- CTA -->
  <div class="flex flex-col items-center gap-4 -mt-8 mb-12">
    <a href="/en/donate" class="px-8 py-3 bg-accent text-white text-sm font-medium rounded-md hover:bg-accent-dark transition-colors">
      Start Donating
    </a>
    <div class="flex items-center gap-4 text-sm text-light-text-secondary dark:text-dark-text-secondary">
      <a href="/en/manifesto" class="hover:text-accent transition-colors">Manifesto</a>
      <span class="text-light-border dark:text-dark-border">·</span>
      <a href="/en/about" class="hover:text-accent transition-colors">About</a>
    </div>
  </div>

  <!-- Org cards -->
  <section class="pb-12">
    <div class="flex items-end justify-between mb-8">
      <div class="flex flex-col gap-1.5">
        <span class="text-xs font-medium text-accent tracking-wider">VERIFIED ORGANIZATIONS</span>
        <h2 class="text-2xl md:text-3xl font-bold font-serif text-light-text dark:text-dark-text">Where Your Donation Goes</h2>
      </div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {orgs.map((org, i) => (
        <div style={`animation: fadeIn 0.4s ease-out ${0.1 + i * 0.08}s both`}>
          <OrgCard
            title={org.data.title}
            description={org.data.description}
            slug={org.slug}
            verified={org.data.verified}
            date={org.data.date}
            image={org.data.image}
          />
        </div>
      ))}
    </div>
  </section>
</Layout>
