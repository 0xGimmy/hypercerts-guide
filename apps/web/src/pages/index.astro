---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import OrgCard from '../components/OrgCard.astro'
import { getCollection } from 'astro:content'

const locale = Astro.currentLocale ?? 'zh'
const orgs = await getCollection('orgs', ({ data }: { data: { locale: string } }) => data.locale === locale)

// Get manifesto description for hero heading (same as old site)
const pages = await getCollection('pages', ({ data }) => data.locale === locale)
const manifesto = pages.find((p) => p.slug.includes('manifesto'))
const heading = manifesto?.data.description ?? (locale === 'zh' ? '揪團行動，超讚出發！' : 'Unite through HyperTogatherings!')
---
<Layout title={locale === 'zh' ? '台灣超讚指南' : 'Taiwan HyperAwesome Guidebook'}>
  <Header slot="header" />

  <!-- Background logo -->
  <img
    src="/background-logo.svg"
    alt=""
    class="fixed top-36 left-[40%] w-96 opacity-[0.03] dark:opacity-[0.08] dark:invert pointer-events-none select-none -z-10"
  />

  <!-- Hero -->
  <div class="p-10 lg:pl-20 lg:pt-20">
    <h1 class="text-3xl font-bold text-left text-primary">{heading}</h1>
    <img src="/underline.svg" alt="" class="w-[570px] h-auto mt-2" />
  </div>

  <!-- Org cards -->
  <div class="flex flex-wrap">
    {orgs.map((org) => (
      <div class="p-4 w-full sm:w-1/2 md:w-1/3">
        <OrgCard
          title={org.data.title}
          description={org.data.description}
          slug={org.slug}
          verified={org.data.verified}
          date={org.data.date}
        />
      </div>
    ))}
  </div>
</Layout>
