---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import LeaderboardIsland from '../components/react/LeaderboardIsland'

const locale = Astro.currentLocale ?? 'zh'
const t = locale === 'zh'
  ? { title: '排行榜' }
  : { title: 'Leaderboard' }
---
<Layout title={t.title} description={locale === 'zh' ? '查看捐款排行榜，感謝每一位支持者的慷慨付出' : 'View the donation leaderboard and celebrate every supporter\'s generosity'}>
  <Header slot="header" />
  <LeaderboardIsland client:only="react" locale={locale} />
</Layout>
