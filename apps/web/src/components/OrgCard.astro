---
interface Props {
  title: string
  description?: string
  slug: string
  verified?: boolean
  date?: Date
  image?: string
}
const { title, description, slug, verified, date, image } = Astro.props
const locale = Astro.currentLocale ?? 'zh'
---
<a href={`/orgs/${slug}`} class="card-lift h-full flex flex-col rounded-lg bg-light-surface dark:bg-dark-surface border border-light-border dark:border-dark-border overflow-hidden cursor-pointer">
  {image ? (
    <div class="h-40 overflow-hidden">
      <img src={image} alt={title} class="w-full h-full object-cover" />
    </div>
  ) : (
    <div class="h-40 bg-accent/10 dark:bg-accent/20"></div>
  )}
  <div class="p-5 flex flex-col gap-2.5">
    {verified && (
      <span class="inline-flex items-center gap-1 text-xs font-medium text-accent bg-accent/10 dark:bg-accent/20 px-2 py-0.5 rounded w-fit">
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
        {locale === 'zh' ? '已驗證' : 'Verified'}
      </span>
    )}
    <h3 class="text-lg font-semibold font-serif text-light-text dark:text-dark-text">{title}</h3>
    {description && (
      <p class="text-sm text-light-text-secondary dark:text-dark-text-secondary leading-relaxed line-clamp-2">{description}</p>
    )}
  </div>
</a>
