---
import '../styles/global.css'

interface Props {
  title?: string
}

const { title = '台灣超讚指南 | Taiwan HyperAwesome Guidebook' } = Astro.props
const locale = Astro.currentLocale ?? 'zh'
const footerLinks = locale === 'zh'
  ? { manifesto: '宣言', about: '關於' }
  : { manifesto: 'Manifesto', about: 'About' }
---
<!doctype html>
<html lang={locale} class="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />
    <script is:inline>
      const theme = localStorage.getItem('theme') ??
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.classList.toggle('dark', theme === 'dark');
    </script>
  </head>
  <body class="min-h-screen flex flex-col font-sans">
    <slot name="header" />
    <main class="flex-1 max-w-5xl mx-auto w-full px-4 py-8">
      <slot />
    </main>
    <footer class="mt-20 border-t-2 pt-8 pb-8 px-4">
      <div class="ml-2 sm:ml-4 flex flex-col sm:flex-row justify-between max-w-5xl mx-auto">
        <div class="flex flex-row space-x-6 text-sm font-semibold text-primary">
          <a class="cursor-pointer border-b-2" href={locale === 'en' ? '/en/manifesto' : '/manifesto'}>{footerLinks.manifesto}</a>
          <a class="cursor-pointer border-b-2" href={locale === 'en' ? '/en/about' : '/about'}>{footerLinks.about}</a>
        </div>
        <p class="text-left text-xs sm:text-right mt-4 sm:mt-0">
          &copy; {new Date().getFullYear()} Taiwan HyperAwesome Guidebook. All rights reserved.
        </p>
      </div>
    </footer>
  </body>
</html>
