---
import '../styles/global.css'

interface Props {
  title?: string
}

const { title = '台灣超讚指南 | Taiwan HyperAwesome Guidebook' } = Astro.props
const locale = Astro.currentLocale ?? 'zh'
const footerLinks = locale === 'zh'
  ? { manifesto: '宣言', about: '關於' }
  : { manifesto: 'Manifesto', about: 'About' }
---
<!doctype html>
<html lang={locale} class="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Serif+TC:wght@400;600;700&display=swap" rel="stylesheet" />
    <script is:inline>
      const theme = localStorage.getItem('theme') ??
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.classList.toggle('dark', theme === 'dark');
    </script>
  </head>
  <body class="min-h-screen flex flex-col font-sans">
    <slot name="header" />
    <main class="flex-1 max-w-5xl mx-auto w-full px-4 py-8">
      <slot />
    </main>
    <footer class="mt-auto border-t border-light-border dark:border-dark-border bg-light-surface dark:bg-dark-surface">
      <div class="max-w-5xl mx-auto px-6 md:px-12 py-6 flex flex-col gap-4">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
          <span class="font-serif font-bold text-base text-light-text dark:text-dark-text">台灣超讚指南</span>
          <nav class="flex items-center gap-5 text-sm text-light-text-secondary dark:text-dark-text-secondary">
            <a href={locale === 'en' ? '/en/donate' : '/donate'} class="hover:text-accent transition-colors">{locale === 'zh' ? '捐款' : 'Donate'}</a>
            <a href="/leaderboard" class="hover:text-accent transition-colors">{locale === 'zh' ? '排行榜' : 'Leaderboard'}</a>
            <a href={locale === 'en' ? '/en/manifesto' : '/manifesto'} class="hover:text-accent transition-colors">{footerLinks.manifesto}</a>
            <a href={locale === 'en' ? '/en/about' : '/about'} class="hover:text-accent transition-colors">{footerLinks.about}</a>
          </nav>
        </div>
        <p class="text-xs text-light-text-muted dark:text-dark-text-muted">&copy; {new Date().getFullYear()} 台灣超讚指南</p>
      </div>
    </footer>
  </body>
</html>
