                          "name": "oP3",
                          "fill": "$--text-primary",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "自成立以來，da0 已經舉辦超過 50 場社群活動，孵化了 10 個以上的公共財專案，並成功透過多輪 Gitcoin Grants 募集資金支持台灣在地的公共財建設。",
                          "lineHeight": 1.8,
                          "fontFamily": "Inter",
                          "fontSize": 15,
                          "fontWeight": "normal"
                        }
